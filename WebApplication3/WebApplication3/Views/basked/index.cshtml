@model Basket
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>КотоГалерея — картины с котами</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="site-wrapper">
        <!-- ========== ШАПКА ========== -->
        <div class="header-main">
            <div class="logotip">
                <div>
                    <ul>
                        <li><img src="data:image/jpeg;base64," alt="Котолавка"></li>
                    </ul>
                </div>
            </div>
            <div class="header_content">
                <div class="form">
                    <input type="text" placeholder="Найти кота или художника... 🐾">
                    <button aria-label="Поиск">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                            <path fill="currentColor" d="M17.892 15.064a8 8 0 1 0-2.828 2.828l2.522 2.522a2 2 0 1 0 2.828-2.828zM11 16a5 5 0 1 1 0-10 5 5 0 0 1 0 10"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="loginform">
                <ul>
                    <li><button><p>😺 кабинет</p></button></li>
                </ul>
                <ul class="cart-icon-wrapper">
                    <li><button><p>🧺 корзина</p></button></li>
                    <span class="cart-count-badge">3</span>
                </ul>
            </div>
        </div>

        <!-- ========== КАРТОЧКИ ТОВАРОВ (КОТЫ НА КАРТИНАХ) ========== -->
        <div class="products-grid">
            <div class="cat-card">
                <img src="https://placekitten.com/220/220?image=1" alt="Пушистый аристократ">
                <h3>Кот-Барон</h3>
                <div class="artist">🎨 Мурр Ван Гог</div>
                <div class="price">2 990 ₽</div>
                <button class="add-to-cart">➕ В корзину</button>
            </div>
            <div class="cat-card">
                <img src="https://placekitten.com/220/220?image=2" alt="Джазовый кот">
                <h3>Усатый джаз</h3>
                <div class="artist">🎷 Котон Монте</div>
                <div class="price">3 450 ₽</div>
                <button class="add-to-cart">➕ В корзину</button>
            </div>

        </div>

        <!-- ========== БЛОК КОРЗИНЫ (ДЕМО-ВЕРСИЯ) ========== -->
        <div class="korsina" id="korsina">
            <div class="cart-header">
                <h2>🧶 Корзина · Котошедевры</h2>
                <button class="clear-cart-btn">🗑️ Очистить</button>
            </div>
            <div class="cart-items-list">
                <div class="cart-item">
                    <div class="cart-item-info">
                        <img class="cart-item-img" src="https://placekitten.com/70/70?image=1" alt="Кот-Барон">
                        <span class="cart-item-title">Кот-Барон <span style="font-size:0.75rem; color:#b97f4b;">(Мурр Ван Гог)</span></span>
                    </div>
                    <div class="cart-item-price">2 990 ₽</div>
                    <div class="item-quantity-control">
                        <button aria-label="уменьшить">−</button>
                        <span class="item-quantity">1</span>
                        <button aria-label="увеличить">+</button>
                    </div>
                    <button class="remove-item" aria-label="удалить">✖</button>
                </div>
                <div class="cart-item">
                    <div class="cart-item-info">
                        <img class="cart-item-img" src="https://placekitten.com/70/70?image=2" alt="Усатый джаз">
                        <span class="cart-item-title">Усатый джаз <span style="font-size:0.75rem;">(Котон Монте)</span></span>
                    </div>
                    <div class="cart-item-price">3 450 ₽</div>
                    <div class="item-quantity-control">
                        <button>−</button>
                        <span class="item-quantity">2</span>
                        <button>+</button>
                    </div>
                    <button class="remove-item">✖</button>
                </div>
                <div class="cart-item">
                    <div class="cart-item-info">
                        <img class="cart-item-img" src="https://placekitten.com/70/70?image=5" alt="Золотой глаз">
                        <span class="cart-item-title">Золотой глаз <span style="font-size:0.75rem;">(Рыжий Рембрандт)</span></span>
                    </div>
                    <div class="cart-item-price">5 200 ₽</div>
                    <div class="item-quantity-control">
                        <button>−</button>
                        <span class="item-quantity">1</span>
                        <button>+</button>
                    </div>
                    <button class="remove-item">✖</button>
                </div>
            </div>
            <div class="cart-summary">
                <div class="total-price">💰 Итого: 13 640 ₽</div>
                <button class="checkout-btn">🐱 Оформить заказ</button>
            </div>
        </div>
        <div style="display: flex; justify-content: center; margin-top: 32px;">
            <div class="demo-note">
                🐾 Демо-версия: корзина показывает пример содержания (только HTML/CSS)
            </div>
        </div>
    </div>
</body>
</html>